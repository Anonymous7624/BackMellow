# =============================================================================
#  BackMellow Analytics — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit your .env file to git.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL database
# ---------------------------------------------------------------------------

# Name of the Postgres database
POSTGRES_DB=umami

# Postgres username (not root — use a dedicated app user)
POSTGRES_USER=umami_user

# STRONG random password — generate with:
#   openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password_here

# ---------------------------------------------------------------------------
# Umami app
# ---------------------------------------------------------------------------

# Secret used to sign session tokens — generate with:
#   openssl rand -hex 32
# Must be at least 32 characters. Changing this invalidates all sessions.
UMAMI_APP_SECRET=CHANGE_ME_at_least_32_chars_random_secret_here

# ---------------------------------------------------------------------------
# Notes
# ---------------------------------------------------------------------------
#
# After starting, visit https://stats.backmellow.com to complete setup:
#
#   Default Umami credentials (CHANGE THESE IMMEDIATELY after first login):
#     Username: admin
#     Password: umami
#
#   1. Log in at https://stats.backmellow.com
#   2. Go to Settings › Websites › Add Website
#   3. Set the name to "BackMellow" and domain to "backmellow.com"
#   4. Copy the Website ID (UUID format)
#   5. In index.html (and policy pages), replace:
#        UMAMI_WEBSITE_ID  → paste the UUID
#        UMAMI_SCRIPT_URL  → https://stats.backmellow.com/script.js
#   6. Commit and push to GitHub Pages
#   7. Verify pageviews in the Umami dashboard
